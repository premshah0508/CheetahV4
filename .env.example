# The First Signer — Elite v4
# Copy this file to .env and customize as needed.

# ── Required ───────────────────────────────────────────────────
# Owner password for admin login (sign in via the "Admin" tab)
# IMPORTANT: Do NOT commit your real password to git.
# Set this in your Render environment variables instead.
OWNER_KEY=change-me-in-production

# ── Optional: Discord webhook alerts for memory warnings ──────
# Create a webhook in your Discord server (channel settings → Integrations → Webhooks)
# and paste the URL here. You'll get pinged at 85% and 92% memory usage.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Optional: Auto-restart when memory hits danger (92%+) ─────
# Default: enabled. Set to "false" to disable (NOT recommended on Render free tier).
# When triggered, the server gracefully saves all data and exits — Render auto-restarts it.
# AUTO_RESTART_ON_DANGER=true

# ── Optional: Server port ─────────────────────────────────────
# Render sets this automatically. Locally, defaults to 3000.
# PORT=3000
